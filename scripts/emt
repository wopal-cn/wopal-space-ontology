#!/bin/bash
#
# emt - 便携式 EllaMaka 启动器
#

set -e

# wopal-space 模式下自动屏蔽 .claude/.agents（由 Flag getter 处理）

# 启用实验性功能（包括 EventSystem，确保 AgentSwitched 等事件生效）
export OPENCODE_EXPERIMENTAL=true

hash -r 2>/dev/null || true

SCRIPT_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
AUTO_APPROVE_SCRIPT="$SCRIPT_DIR/oc-auto-approve.py"

CWD="$(pwd)"
SPACE_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"
LOG_DIR="$SPACE_ROOT/.wopal-space/logs"
SESSION_NAME="em-$(basename "$CWD")"

BACKEND_PORT=4096
ELLAMAKA_LOG="$LOG_DIR/ellamaka.log"
BACKEND_LOG="$LOG_DIR/emt-backend.log"
BACKEND_PID_FILE="$LOG_DIR/emt-backend.pid"

NO_AUTO_APPROVE=false DEBUG_MODE=false ATTACH_MODE=false NO_WOPAL_SPACE=false
DEBUG_MODULES=""
TRACE_MODE=false TRACE_MODULES=""
COMMAND=""
OPENCODE_ARGS=()

# --- 参数解析 ---

show_help() {
    cat << 'EOF'
emt - 便携式 EllaMaka 启动器

用法:
  emt                    启动会话（名称 = em-<当前目录名>）
  emt attach [<args>]    attach 模式（共享后端 :4096）
  emt serve [--debug]    启动后端服务（不进 tmux）
  emt status             查看会话状态
  emt stop               停止后端服务
  emt help               显示本帮助

选项:
  --debug [模块]         调试模式（模块: core|rules|task|memory|context|all，默认 all）
  --trace [模块]         启用 trace 日志（更详细的诊断，隐含 --debug）
  --no-auto-approve      禁用自动授权
  -ns                    禁用 WopalSpace 模式（原生 opencode 行为）

会话选择:
  有运行中的会话时列出，输编号/名称进入，回车新建
EOF
    exit 0
}

SUBCOMMANDS="attach|status|stop|serve|help"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) OPENCODE_ARGS+=(--help); shift ;;
        --no-auto-approve) NO_AUTO_APPROVE=true; shift ;;
        -ns) NO_WOPAL_SPACE=true; shift ;;

        --trace)
            TRACE_MODE=true; DEBUG_MODE=true
            if [[ $# -gt 1 ]] && [[ ! "$2" =~ ^- ]]; then
                TRACE_MODULES="$2"; DEBUG_MODULES="$2"; shift 2
            else
                TRACE_MODULES="all"; DEBUG_MODULES="all"; shift
            fi
            ;;
        --debug)
            DEBUG_MODE=true
            if [[ $# -gt 1 ]] && [[ ! "$2" =~ ^- ]]; then
                DEBUG_MODULES="$2"; shift 2
            else
                DEBUG_MODULES="all"; shift
            fi
            ;;
        --) shift; OPENCODE_ARGS+=("$@"); break ;;
        -*) OPENCODE_ARGS+=("$1"); shift ;;
        *)
            if [[ -z "$COMMAND" ]] && [[ "$1" =~ ^($SUBCOMMANDS)$ ]]; then
                COMMAND="$1"; shift
            else
                echo "emt: 未知参数 '$1' (子命令: $SUBCOMMANDS)" >&2; exit 1
            fi
            ;;
    esac
done

# --- 计算新日志环境变量 ---
if [ "$TRACE_MODE" = true ]; then
    LOG_LEVEL="trace"
    LOG_MODULES="${TRACE_MODULES}"
elif [ "$DEBUG_MODE" = true ]; then
    LOG_LEVEL="debug"
    LOG_MODULES="${DEBUG_MODULES}"
else
    LOG_LEVEL=""
    LOG_MODULES=""
fi

# "all" = 不做模块过滤，留空让 logger 视为 null（不过滤）
[[ "$LOG_MODULES" == "all" ]] && LOG_MODULES=""

if [ "$NO_WOPAL_SPACE" = true ]; then
    WOPAL_SPACE_ARGS=(--no-wopal-space)
else
    WOPAL_SPACE_ARGS=()
fi

# --- 后端管理 ---

is_backend_running() {
    lsof -ti :"$BACKEND_PORT" > /dev/null 2>&1
}

wait_backend() {
    for ((i = 0; i < 60; i++)); do
        curl -sf "http://127.0.0.1:$BACKEND_PORT/health" > /dev/null 2>&1 && return 0
        sleep 0.5
    done
    return 1
}

start_backend() {
    mkdir -p "$LOG_DIR"

    local log_level="INFO"
    [ "$DEBUG_MODE" = true ] && log_level="DEBUG"

    local serve_args=(serve --port $BACKEND_PORT --mdns --mdns-domain ellamaka.local --print-logs --log-level $log_level "${WOPAL_SPACE_ARGS[@]}")

    nohup env \
        WOPAL_PLUGIN_LOG_LEVEL="${LOG_LEVEL}" \
        WOPAL_PLUGIN_LOG_MODULES="${LOG_MODULES}" \
        WOPAL_PLUGIN_LOG_FILE="$LOG_DIR/wopal-plugins-debug.log" \
        ellamaka "${serve_args[@]}" > "$BACKEND_LOG" 2>&1 &

    # 记录 PID 和启动目录，stop 时用于校验
    { echo $!; echo "$CWD"; } > "$BACKEND_PID_FILE"
}

stop_backend() {
    local pid="" start_dir="" has_pid_file=false

    if [ -f "$BACKEND_PID_FILE" ]; then
        has_pid_file=true
        { read -r pid; read -r start_dir; } < "$BACKEND_PID_FILE"

        local current_dir="$(pwd)"
        if [ "$current_dir" != "$start_dir" ]; then
            echo "emt: 当前目录与启动目录不一致，无法停止后端" >&2
            echo "  启动目录: $start_dir" >&2
            echo "  当前目录: $current_dir" >&2
            echo "  请 cd 到 $start_dir 后执行 emt stop" >&2
            exit 1
        fi
    fi

    local port_pid
    port_pid="$(lsof -ti :$BACKEND_PORT 2>/dev/null)" || true

    if [ -z "$pid" ] && [ -z "$port_pid" ]; then
        echo "后端服务未运行"
        return
    fi

    rm -f "$BACKEND_PID_FILE" "$BACKEND_LOG" "$LOG_DIR/wopal-plugins-debug.log" || true

    for p in $pid $port_pid; do
        [ -n "$p" ] && kill "$p" 2>/dev/null || true
    done

    echo "后端服务已停止"
}

# --- 状态查询 ---

show_status() {
    echo "EllaMaka 会话状态"
    echo ""

    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null) || sessions=""

    local em_sessions=()
    local monitor_sessions=()

    if [ -n "$sessions" ]; then
        while IFS= read -r s; do
            if [[ "$s" == auto-approver-* ]]; then
                monitor_sessions+=("$s")
            else
                em_sessions+=("$s")
            fi
        done <<< "$sessions"
    fi

    if [ ${#em_sessions[@]} -eq 0 ]; then
        echo "没有 EllaMaka 会话运行中"
    else
        echo "EllaMaka 会话:"
        for s in "${em_sessions[@]}"; do
            local session_dir
            session_dir=$(tmux display-message -t "=$s" -p "#{pane_current_path}" 2>/dev/null || echo "未知")
            local monitor="auto-approver-$s"
            local status="无监控"
            tmux has-session -t "=$monitor" 2>/dev/null && status="监控中 ($monitor)"
            echo "  $s"
            echo "    目录: $session_dir | 状态: $status"
            if [ -d "$session_dir/logs" ]; then
                local log_count
                log_count=$(find "$session_dir/logs" -name "*.log" -type f 2>/dev/null | wc -l | tr -d ' ')
                [ "$log_count" -gt 0 ] && echo "    日志: $session_dir/logs ($log_count 个)"
            fi
        done
    fi

    echo ""

    local orphan_monitors=()
    for m in "${monitor_sessions[@]}"; do
        local target="${m#auto-approver-}"
        tmux has-session -t "=$target" 2>/dev/null || orphan_monitors+=("$m")
    done

    if [ ${#orphan_monitors[@]} -gt 0 ]; then
        echo "孤立监控会话:"
        for m in "${orphan_monitors[@]}"; do
            echo "  $m  (tmux kill-session -t $m)"
        done
    fi

    echo ""
    echo "后端服务:"
    if is_backend_running; then
        local bpid="(unknown)" bdir=""
        if [ -f "$BACKEND_PID_FILE" ]; then
            { read -r bpid; read -r bdir; } < "$BACKEND_PID_FILE"
        fi
        echo "  运行中 → http://127.0.0.1:$BACKEND_PORT"
        [ -n "$bpid" ] && echo "  PID: $bpid"
        [ -n "$bdir" ] && echo "  目录: $bdir"
        [ -f "$BACKEND_LOG" ] && echo "  日志: $BACKEND_LOG"
    else
        echo "  未运行"
    fi
}

# --- 子命令分发 ---

case "$COMMAND" in
    status) show_status; exit 0 ;;
    stop)   stop_backend; exit 0 ;;
    help)   show_help; exit 0 ;;
    serve)
        mkdir -p "$LOG_DIR"
        [ "$DEBUG_MODE" = true ] && {
            echo "emt: 调试模式 [$LOG_LEVEL${LOG_MODULES:+:$LOG_MODULES}] → logs/"
        }
        start_backend
        echo -n "emt: 等待后端就绪"
        wait_backend && echo " OK" || echo " 超时"
        echo "emt: 后端已启动 → http://127.0.0.1:$BACKEND_PORT"
        exit 0
        ;;
    attach) ATTACH_MODE=true ;;
esac

# 一次性命令（--help/--version）不走 tmux，直接在前台执行
if [[ -z "$COMMAND" ]]; then
    for arg in "${OPENCODE_ARGS[@]}"; do
        if [[ "$arg" == "--help" ]] || [[ "$arg" == "--version" ]]; then
            exec ellamaka "${OPENCODE_ARGS[@]}"
        fi
    done
fi

# --- 会话管理 ---

get_next_session_name() {
    local base="$1"
    tmux has-session -t "=$base" 2>/dev/null || { echo "$base"; return; }
    local num=1
    local name="${base}-${num}"
    while tmux has-session -t "=$name" 2>/dev/null; do
        num=$((num + 1))
        name="${base}-${num}"
    done
    echo "$name"
}

start_auto_approve() {
    local session="$1"
    if [ ! -f "$AUTO_APPROVE_SCRIPT" ]; then
        echo "emt: 找不到 auto-approve 脚本" >&2
        return
    fi

    local log_arg="$([ -d "$LOG_DIR" ] && echo "$LOG_DIR")"
    local debug_flag="$([ "$DEBUG_MODE" = true ] && echo true || echo false)"

    nohup python3 "$AUTO_APPROVE_SCRIPT" start "$session" "$debug_flag" "10" "$log_arg" \
        >/dev/null 2>&1 &
    echo "emt: 自动授权已启动 (PID $!)"
}

create_session() {
    local name="$1"

    if [ "$ATTACH_MODE" = false ] && is_backend_running; then
        echo ""
        read -p "检测到后端 :$BACKEND_PORT 已运行，切换 attach 模式？[y/N]: " choice
        case "$choice" in
            [Yy]*) ATTACH_MODE=true ;;
        esac
    fi

    mkdir -p "$LOG_DIR"
    [ "$DEBUG_MODE" = true ] && echo "emt: 调试模式 [$LOG_LEVEL${LOG_MODULES:+:$LOG_MODULES}] → logs/"

    echo "emt: 创建会话 \"$name\"$([ "$ATTACH_MODE" = true ] && echo " [attach]") → $CWD"

    [ "$NO_AUTO_APPROVE" = false ] && start_auto_approve "$name"

    if [ "$ATTACH_MODE" = true ]; then
        if ! is_backend_running; then
            echo "emt: 启动后端..."
            start_backend
            echo -n "emt: 等待后端就绪"
            wait_backend && echo " OK" || echo " 超时"
        else
            echo "emt: 连接已有后端 :$BACKEND_PORT"
        fi

        tmux new-session -s "$name" -c "$CWD" -- \
            ellamaka attach "http://localhost:$BACKEND_PORT" --dir "$CWD" "${WOPAL_SPACE_ARGS[@]}" "${OPENCODE_ARGS[@]}"
    else
        local debug_args=()
        if [ "$DEBUG_MODE" = true ]; then
            debug_args=(--log-level DEBUG --print-logs)
        fi

        if [ "$DEBUG_MODE" = true ]; then
            tmux new-session -s "$name" -c "$CWD" \
                -e "WOPAL_PLUGIN_LOG_LEVEL=$LOG_LEVEL" \
                -e "WOPAL_PLUGIN_LOG_MODULES=$LOG_MODULES" \
                -e "WOPAL_PLUGIN_LOG_FILE=$LOG_DIR/wopal-plugins-debug.log" \
                -e "WOPAL_DEBUG_LOG_DIR=$LOG_DIR" \
                -- bash -c 'exec ellamaka "$@" 2>> "'"$ELLAMAKA_LOG"'"' _ "${debug_args[@]}" "${WOPAL_SPACE_ARGS[@]}" "${OPENCODE_ARGS[@]}"
        else
            tmux new-session -s "$name" -c "$CWD" -- \
                ellamaka "${WOPAL_SPACE_ARGS[@]}" "${OPENCODE_ARGS[@]}"
        fi
    fi
}

# --- 主逻辑 ---

SESSIONS=()
while IFS= read -r line; do
    [[ "$line" != auto-approver-* ]] && SESSIONS+=("$line")
done < <(tmux list-sessions -F "#{session_name}" 2>/dev/null)

if [ ${#SESSIONS[@]} -gt 0 ]; then
    default_new_name="$(get_next_session_name "$SESSION_NAME")"
    echo ""
    echo "  EllaMaka"
    echo "  ─────────────────────"
    for i in "${!SESSIONS[@]}"; do
        dir=$(tmux display-message -t "=${SESSIONS[$i]}" -p "#{pane_current_path}" 2>/dev/null || echo "?")
        # 用 ~ 缩写路径
        [[ "$dir" == "$HOME"* ]] && dir="~${dir#$HOME}"
        printf "  %d  %-28s %s\n" "$((i + 1))" "${SESSIONS[$i]}" "$dir"
    done
    echo ""
    printf "  %-2s %s\n" "↩" "新建 $default_new_name"
    printf "  %-2s %s\n" "q" "退出"
    echo ""
    read -p "  编号/名称 > " choice

    case "$choice" in
        "")  create_session "$default_new_name" ;;
        q|Q) exit 0 ;;
        *)
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#SESSIONS[@]} ]; then
                tmux attach-session -t "=${SESSIONS[$((choice - 1))]}"
            elif tmux has-session -t "=$choice" 2>/dev/null; then
                tmux attach-session -t "=$choice"
            else
                create_session "$choice"
            fi
            ;;
    esac
else
    create_session "$SESSION_NAME"
fi
