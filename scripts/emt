#!/bin/bash
#
# emt - 便携式 EllaMaka 启动器
#

set -e

# wopal-space 模式下自动屏蔽 .claude/.agents（由 Flag getter 处理）

# 启用实验性功能（包括 EventSystem，确保 AgentSwitched 等事件生效）
export OPENCODE_EXPERIMENTAL=true

hash -r 2>/dev/null || true

if ! command -v ellamaka > /dev/null 2>&1; then
    echo "emt: 找不到 ellamaka 命令，请检查 PATH 或 WOPAL_HOME/bin" >&2
    exit 1
fi
if ! command -v tmux > /dev/null 2>&1; then
    echo "emt: 找不到 tmux 命令，请安装 tmux" >&2
    exit 1
fi
if ! command -v python3 > /dev/null 2>&1; then
    echo "emt: 找不到 python3 命令" >&2
    exit 1
fi
if ! command -v curl > /dev/null 2>&1; then
    echo "emt: 找不到 curl 命令" >&2
    exit 1
fi
if ! command -v lsof > /dev/null 2>&1; then
    echo "emt: 找不到 lsof 命令" >&2
    exit 1
fi

if ! command -v tmux > /dev/null 2>&1; then
    echo "emt: 找不到 tmux 命令，请安装 tmux" >&2
    exit 1
fi

SCRIPT_PATH="$(python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
AUTO_APPROVE_SCRIPT="$SCRIPT_DIR/oc-auto-approve.py"

CWD="$(pwd)"

detect_wopal_space_root() {
  local dir="$1"
  while true; do
    if [ -f "$dir/.wopal/.git" ]; then
      echo "$dir"
      return 0
    fi
    [ "$dir" = "/" ] && break
    [ "$dir" = "$HOME" ] && break
    dir="$(dirname "$dir")"
  done
  return 1
}

WOPAL_HOME_DIR="${WOPAL_HOME:-$HOME/.wopal}"
GLOBAL_LOG_DIR="$WOPAL_HOME_DIR/logs"
BACKEND_STATE_DIR="$WOPAL_HOME_DIR/ellamaka/state"

if SPACE_ROOT="$(detect_wopal_space_root "$CWD")"; then
  SPACE_LOG_DIR="$SPACE_ROOT/.wopal-space/logs"
else
  SPACE_LOG_DIR=""
fi

mkdir -p "$GLOBAL_LOG_DIR" "$BACKEND_STATE_DIR"
[ -n "$SPACE_LOG_DIR" ] && mkdir -p "$SPACE_LOG_DIR"

SESSION_NAME="em-$(basename "$CWD")"

BACKEND_PORT_BASE=4096
BACKEND_PORT=""  # 运行时动态确定
BACKEND_PID_FILE="$BACKEND_STATE_DIR/ellamaka.pid"
ELLAMAKA_LOG="${SPACE_LOG_DIR:-$GLOBAL_LOG_DIR}/ellamaka.log"

NO_AUTO_APPROVE=false DEBUG_MODE=false ATTACH_MODE=false DISABLE_WOPALSPACE=false
DEBUG_MODULES=""
TRACE_MODE=false TRACE_MODULES=""
COMMAND=""
OPENCODE_ARGS=()
SERVER_PASSWORD=""

# --- 参数解析 ---

show_help() {
    cat << 'EOF'
emt - 便携式 EllaMaka 启动器

用法:
  emt                    启动会话（名称 = em-<当前目录名>）
  emt attach [<args>]    attach 模式（连接已有后端）
  emt serve [--debug]    启动后端服务（不进 tmux）
  emt status             查看会话状态
  emt stop               停止后端服务
  emt help               显示本帮助

选项:
  --debug [模块]         调试模式（模块: core|rules|task|memory|context|all，默认 all）
  --trace [模块]         启用 trace 日志（更详细的诊断，隐含 --debug）
  --no-auto-approve      禁用自动授权
  -ns                    禁用 WopalSpace 模式（原生 opencode 行为）
  --password <密码>      设置服务器密码（自动绑定 0.0.0.0，支持局域网访问）

端口分配:
  从 4096 开始自动寻找可用端口，支持多个实例并行

会话选择:
  有运行中的会话时列出，输编号/名称进入，回车新建
EOF
    exit 0
}

SUBCOMMANDS="attach|status|stop|serve|help"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) OPENCODE_ARGS+=(--help); shift ;;
        --no-auto-approve) NO_AUTO_APPROVE=true; shift ;;
        -ns) DISABLE_WOPALSPACE=true; shift ;;
        --password)
            if [[ $# -gt 1 ]] && [[ ! "$2" =~ ^- ]]; then
                SERVER_PASSWORD="$2"; shift 2
            else
                echo "emt: --password 需要参数" >&2; exit 1
            fi
            ;;

        --trace)
            TRACE_MODE=true; DEBUG_MODE=true
            if [[ $# -gt 1 ]] && [[ ! "$2" =~ ^- ]]; then
                TRACE_MODULES="$2"; DEBUG_MODULES="$2"; shift 2
            else
                TRACE_MODULES="all"; DEBUG_MODULES="all"; shift
            fi
            ;;
        --debug)
            DEBUG_MODE=true
            if [[ $# -gt 1 ]] && [[ ! "$2" =~ ^- ]]; then
                DEBUG_MODULES="$2"; shift 2
            else
                DEBUG_MODULES="all"; shift
            fi
            ;;
        --) shift; OPENCODE_ARGS+=("$@"); break ;;
        -*) OPENCODE_ARGS+=("$1"); shift ;;
        *)
            if [[ -z "$COMMAND" ]] && [[ "$1" =~ ^($SUBCOMMANDS)$ ]]; then
                COMMAND="$1"; shift
            else
                echo "emt: 未知参数 '$1' (子命令: $SUBCOMMANDS)" >&2; exit 1
            fi
            ;;
    esac
done

# --- 计算新日志环境变量 ---
if [ "$TRACE_MODE" = true ]; then
    LOG_LEVEL="trace"
    LOG_MODULES="${TRACE_MODULES}"
elif [ "$DEBUG_MODE" = true ]; then
    LOG_LEVEL="debug"
    LOG_MODULES="${DEBUG_MODULES}"
else
    LOG_LEVEL=""
    LOG_MODULES=""
fi

# "all" = 不做模块过滤，留空让 logger 视为 null（不过滤）
[[ "$LOG_MODULES" == "all" ]] && LOG_MODULES=""

if [ "$DISABLE_WOPALSPACE" = true ]; then
    WOPAL_SPACE_ARGS=(--disable-wopalspace)
else
    WOPAL_SPACE_ARGS=()
fi

# --- 后端管理 ---

# 从 BASE 开始找可用端口
find_available_port() {
    local port=$BACKEND_PORT_BASE
    local max=$((BACKEND_PORT_BASE + 100))
    while [ $port -lt $max ]; do
        if ! lsof -ti :$port > /dev/null 2>&1; then
            echo $port
            return 0
        fi
        port=$((port + 1))
    done
    return 1
}

# 从 BASE 开始扫描，返回第一个 ellamaka 端口
find_ellamaka_port() {
    local port=$BACKEND_PORT_BASE
    local max=$((BACKEND_PORT_BASE + 100))
    while [ $port -lt $max ]; do
        local port_pid
        port_pid="$(lsof -ti :$port 2>/dev/null)" || true
        if [ -n "$port_pid" ]; then
            for pid in $port_pid; do
                if ps -p "$pid" -o comm= 2>/dev/null | grep -q "ellamaka"; then
                    echo $port
                    return 0
                fi
            done
        fi
        port=$((port + 1))
    done
    return 1
}

is_backend_running() {
    BACKEND_PORT="$(find_ellamaka_port)" || BACKEND_PORT=""
    [ -n "$BACKEND_PORT" ]
}

wait_backend() {
    local port="$BACKEND_PORT"
    for ((i = 0; i < 60; i++)); do
        curl -sf "http://127.0.0.1:$port/health" > /dev/null 2>&1 && return 0
        # 等待期间检查后端是否已崩溃
        if [ -f "$BACKEND_PID_FILE" ]; then
            local check_pid
            read -r check_pid < "$BACKEND_PID_FILE"
            if ! kill -0 "$check_pid" 2>/dev/null; then
                echo "" >&2
                echo "emt: 后端在启动期间崩溃 (PID $check_pid)" >&2
                local check_log
                { read -r _; read -r _; read -r _; read -r check_log || true; } < "$BACKEND_PID_FILE"
                if [ -n "$check_log" ] && [ -f "$check_log" ]; then
                    echo "emt: 日志尾部 ($check_log):" >&2
                    tail -30 "$check_log" >&2
                fi
                rm -f "$BACKEND_PID_FILE"
                return 2
            fi
        fi
        sleep 0.5
    done
    return 1
}

# 检查刚启动的后端是否存活，若已崩溃则清理残留并输出日志尾部
verify_backend_alive() {
    local pid="$1" log="$2"
    sleep 1
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "" >&2
        echo "emt: 后端启动失败 (PID $pid 已退出)" >&2
        if [ -f "$log" ]; then
            echo "emt: 日志尾部 ($log):" >&2
            tail -30 "$log" >&2
        fi
        rm -f "$BACKEND_PID_FILE" "$log"
        exit 1
    fi
}

start_backend() {
    local log_level="INFO"
    [ "$DEBUG_MODE" = true ] && log_level="DEBUG"

    # 动态获取可用端口
    BACKEND_PORT="$(find_available_port)" || {
        echo "emt: 无法找到可用端口 ($BACKEND_PORT_BASE-$((BACKEND_PORT_BASE+100)))" >&2
        return 1
    }
    echo "emt: 使用端口 $BACKEND_PORT"

    # 构建 serve 参数
    local serve_args=(serve --port $BACKEND_PORT --mdns --mdns-domain ellamaka.local --print-logs --log-level $log_level "${WOPAL_SPACE_ARGS[@]}")

    # 如果设置了密码，绑定到 0.0.0.0 支持局域网访问
    local hostname="127.0.0.1"
    if [ -n "$SERVER_PASSWORD" ]; then
        hostname="0.0.0.0"
        serve_args+=(--hostname "$hostname")
        echo "emt: 已设置密码，服务绑定到 $hostname (局域网可访问)"
    fi

    # serve 日志路由：非 debug → 全局，debug → 空间
    local backend_log="$GLOBAL_LOG_DIR/ellamaka-serve.log"
    local plugin_log_file=""
    if [ "$DEBUG_MODE" = true ]; then
        backend_log="${SPACE_LOG_DIR:-$GLOBAL_LOG_DIR}/ellamaka-serve.log"
        plugin_log_file="${SPACE_LOG_DIR:-$GLOBAL_LOG_DIR}/wopal-plugins-debug.log"
    fi

    local env_vars=(WOPAL_HOME="$WOPAL_HOME_DIR")
    [ -n "$LOG_LEVEL" ] && env_vars+=(WOPAL_PLUGIN_LOG_LEVEL="$LOG_LEVEL")
    [ -n "$LOG_MODULES" ] && env_vars+=(WOPAL_PLUGIN_LOG_MODULES="$LOG_MODULES")
    [ -n "$plugin_log_file" ] && env_vars+=(WOPAL_PLUGIN_LOG_FILE="$plugin_log_file")
    [ -n "$SERVER_PASSWORD" ] && env_vars+=(OPENCODE_SERVER_PASSWORD="$SERVER_PASSWORD")

    nohup env "${env_vars[@]}" ellamaka "${serve_args[@]}" > "$backend_log" 2>&1 &
    local serve_pid=$!

    # 记录 PID、启动目录、后端日志路径、端口、主机名、密码
    { echo "$serve_pid"; echo "$CWD"; echo "$backend_log"; echo "$BACKEND_PORT"; echo "$hostname"; echo "$SERVER_PASSWORD"; } > "$BACKEND_PID_FILE"

    verify_backend_alive "$serve_pid" "$backend_log"
}

stop_backend() {
    local pid="" start_dir="" backend_log="" port=""

    if [ -f "$BACKEND_PID_FILE" ]; then
        { read -r pid; read -r start_dir; read -r backend_log; read -r port || true; } < "$BACKEND_PID_FILE"
    fi

    # 扫描所有 ellamaka 端口
    local ellamaka_pids=""
    local scan_port=$BACKEND_PORT_BASE
    local max=$((BACKEND_PORT_BASE + 100))
    while [ $scan_port -lt $max ]; do
        local port_pid
        port_pid="$(lsof -ti :$scan_port 2>/dev/null)" || true
        if [ -n "$port_pid" ]; then
            for p in $port_pid; do
                if ps -p "$p" -o comm= 2>/dev/null | grep -q "ellamaka"; then
                    ellamaka_pids="$ellamaka_pids $p"
                fi
            done
        fi
        scan_port=$((scan_port + 1))
    done

    if [ -z "$pid" ] && [ -z "$ellamaka_pids" ]; then
        echo "后端服务未运行"
        return
    fi

    rm -f "$BACKEND_PID_FILE" "$backend_log" || true

    # 只杀 ellamaka 进程
    for p in $pid $ellamaka_pids; do
        [ -n "$p" ] && kill "$p" 2>/dev/null || true
    done

    echo "后端服务已停止"
}

# --- 状态查询 ---

show_status() {
    echo "EllaMaka 会话状态"
    echo ""

    local sessions
    sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null) || sessions=""

    local em_sessions=()
    local monitor_sessions=()

    if [ -n "$sessions" ]; then
        while IFS= read -r s; do
            if [[ "$s" == auto-approver-* ]]; then
                monitor_sessions+=("$s")
            else
                em_sessions+=("$s")
            fi
        done <<< "$sessions"
    fi

    if [ ${#em_sessions[@]} -eq 0 ]; then
        echo "没有 EllaMaka 会话运行中"
    else
        echo "EllaMaka 会话:"
        for s in "${em_sessions[@]}"; do
            local session_dir
            session_dir=$(tmux display-message -t "=$s" -p "#{pane_current_path}" 2>/dev/null || echo "未知")
            local monitor="auto-approver-$s"
            local status="无监控"
            tmux has-session -t "=$monitor" 2>/dev/null && status="监控中 ($monitor)"
            echo "  $s"
            echo "    目录: $session_dir | 状态: $status"
            local log_dir="$session_dir/.wopal-space/logs"
            [ ! -d "$log_dir" ] && log_dir="$session_dir/logs"
            if [ -d "$log_dir" ]; then
                local log_count
                log_count=$(find "$log_dir" -name "*.log" -type f 2>/dev/null | wc -l | tr -d ' ')
                [ "$log_count" -gt 0 ] && echo "    日志: $log_dir ($log_count 个)"
            fi
        done
    fi

    echo ""

    local orphan_monitors=()
    for m in "${monitor_sessions[@]}"; do
        local target="${m#auto-approver-}"
        tmux has-session -t "=$target" 2>/dev/null || orphan_monitors+=("$m")
    done

    if [ ${#orphan_monitors[@]} -gt 0 ]; then
        echo "孤立监控会话:"
        for m in "${orphan_monitors[@]}"; do
            echo "  $m  (tmux kill-session -t $m)"
        done
    fi

    echo ""
    echo "后端服务:"
    if is_backend_running; then
        local bpid="(unknown)" bdir="" blog="" bport="$BACKEND_PORT" bhost="127.0.0.1"
        if [ -f "$BACKEND_PID_FILE" ]; then
            { read -r bpid; read -r bdir; read -r blog; read -r bport; read -r bhost || true; } < "$BACKEND_PID_FILE"
        fi
        echo "  运行中 → http://$bhost:$bport"
        echo "  mDNS: ellamaka.local:$bport"
        if [ "$bhost" = "0.0.0.0" ]; then
            local lan_ip
            lan_ip="$(ifconfig | grep -E 'inet.*broadcast' | grep -v '127.0.0.1' | head -1 | awk '{print $2}' || echo "未知")"
            echo "  局域网: http://$lan_ip:$bport"
            echo "  认证: 需要密码"
        fi
        [ -n "$bpid" ] && echo "  PID: $bpid"
        [ -n "$bdir" ] && echo "  目录: $bdir"
        [ -n "$blog" ] && [ -f "$blog" ] && echo "  日志: $blog"
    else
        # 检查端口是否被其他应用占用
        local port_pid
        port_pid="$(lsof -ti :$BACKEND_PORT_BASE 2>/dev/null)" || true
        if [ -n "$port_pid" ]; then
            echo "  端口 $BACKEND_PORT_BASE 被占用，但非 ellamaka 进程 (PID: $port_pid)"
        else
            echo "  未运行"
        fi
    fi
}

# --- 子命令分发 ---

case "$COMMAND" in
    status) show_status; exit 0 ;;
    stop)   stop_backend; exit 0 ;;
    help)   show_help; exit 0 ;;
    serve)
        [ "$DEBUG_MODE" = true ] && {
            echo "emt: 调试模式 [$LOG_LEVEL${LOG_MODULES:+:$LOG_MODULES}] → logs/"
        }
        start_backend
        echo -n "emt: 等待后端就绪"
        wait_backend
        case $? in
            0) echo " OK" ;;
            1) local _pid _cwd _log; { read -r _pid; read -r _cwd; read -r _log || true; } < "$BACKEND_PID_FILE"; echo " 超时"; echo "emt: 后端可能仍在启动中，查看日志: ${_log:-未知}" ;;
            *) exit 1 ;;
        esac
        echo "emt: 后端已启动 → http://127.0.0.1:$BACKEND_PORT"
        exit 0
        ;;
    attach) ATTACH_MODE=true ;;
esac

# 一次性命令（--help/--version）不走 tmux，直接在前台执行
if [[ -z "$COMMAND" ]]; then
    for arg in "${OPENCODE_ARGS[@]}"; do
        if [[ "$arg" == "--help" ]] || [[ "$arg" == "--version" ]]; then
            exec ellamaka "${OPENCODE_ARGS[@]}"
        fi
    done
fi

# --- 会话管理 ---

get_next_session_name() {
    local base="$1"
    tmux has-session -t "=$base" 2>/dev/null || { echo "$base"; return; }
    local num=1
    local name="${base}-${num}"
    while tmux has-session -t "=$name" 2>/dev/null; do
        num=$((num + 1))
        name="${base}-${num}"
    done
    echo "$name"
}

start_auto_approve() {
    local session="$1"
    if [ ! -f "$AUTO_APPROVE_SCRIPT" ]; then
        echo "emt: 找不到 auto-approve 脚本" >&2
        return
    fi

    local log_arg="$([ -d "$SPACE_LOG_DIR" ] && echo "$SPACE_LOG_DIR" || echo "$GLOBAL_LOG_DIR")"
    local debug_flag="$([ "$DEBUG_MODE" = true ] && echo true || echo false)"

    nohup python3 "$AUTO_APPROVE_SCRIPT" start "$session" "$debug_flag" "10" "$log_arg" \
        >/dev/null 2>&1 &
    echo "emt: 自动授权已启动 (PID $!)"
}

create_session() {
    local name="$1"

    if [ "$ATTACH_MODE" = false ] && is_backend_running; then
        echo ""
        read -p "检测到后端 :$BACKEND_PORT 已运行，切换 attach 模式？[y/N]: " choice
        case "$choice" in
            [Yy]*) ATTACH_MODE=true ;;
        esac
    fi

    [ "$DEBUG_MODE" = true ] && echo "emt: 调试模式 [$LOG_LEVEL${LOG_MODULES:+:$LOG_MODULES}] → logs/"

    echo "emt: 创建会话 \"$name\"$([ "$ATTACH_MODE" = true ] && echo " [attach]") → $CWD"

    [ "$NO_AUTO_APPROVE" = false ] && start_auto_approve "$name"

    if [ "$ATTACH_MODE" = true ]; then
        if ! is_backend_running; then
            echo "emt: 启动后端..."
            start_backend
            echo -n "emt: 等待后端就绪"
            wait_backend && echo " OK" || echo " 超时"
        else
            echo "emt: 连接已有后端 :$BACKEND_PORT"
        fi

        # 从 PID 文件读取连接信息
        local connect_url="" saved_password=""
        if [ -f "$BACKEND_PID_FILE" ]; then
            local _pid _dir _log _port _host _pass
            { read -r _pid; read -r _dir; read -r _log; read -r _port; read -r _host; read -r _pass || true; } < "$BACKEND_PID_FILE"
            saved_password="$_pass"
            if [ "$_host" = "0.0.0.0" ]; then
                local lan_ip
                lan_ip="$(ifconfig | grep -E 'inet.*broadcast' | grep -v '127.0.0.1' | head -1 | awk '{print $2}' || echo "localhost")"
                connect_url="http://$lan_ip:$_port"
            else
                connect_url="http://localhost:$_port"
            fi
        fi

        # 构建 attach 参数
        local attach_args=()
        [ -n "$saved_password" ] && attach_args+=(--password "$saved_password")

        tmux new-session -s "$name" -c "$CWD" -- \
            env "WOPAL_HOME=$WOPAL_HOME_DIR" \
            ellamaka attach "$connect_url" --dir "$CWD" "${attach_args[@]}" "${WOPAL_SPACE_ARGS[@]}" "${OPENCODE_ARGS[@]}"
    else
        local debug_args=()
        if [ "$DEBUG_MODE" = true ]; then
            debug_args=(--log-level DEBUG --print-logs)
        fi

        if [ "$DEBUG_MODE" = true ]; then
            local tui_log_dir="${SPACE_LOG_DIR:-$GLOBAL_LOG_DIR}"
            tmux new-session -s "$name" -c "$CWD" -- \
                env "WOPAL_HOME=$WOPAL_HOME_DIR" \
                "WOPAL_PLUGIN_LOG_LEVEL=$LOG_LEVEL" \
                "WOPAL_PLUGIN_LOG_MODULES=$LOG_MODULES" \
                "WOPAL_PLUGIN_LOG_FILE=$tui_log_dir/wopal-plugins-debug.log" \
                "WOPAL_DEBUG_LOG_DIR=$tui_log_dir" \
                bash -c 'exec ellamaka "$@" 2>> "'"$ELLAMAKA_LOG"'"' _ "${debug_args[@]}" "${WOPAL_SPACE_ARGS[@]}" "${OPENCODE_ARGS[@]}"
        else
            tmux new-session -s "$name" -c "$CWD" -- \
                env "WOPAL_HOME=$WOPAL_HOME_DIR" \
                ellamaka "${WOPAL_SPACE_ARGS[@]}" "${OPENCODE_ARGS[@]}"
        fi
    fi
}

# --- 主逻辑 ---

SESSIONS=()
while IFS= read -r line; do
    [[ "$line" != auto-approver-* ]] && SESSIONS+=("$line")
done < <(tmux list-sessions -F "#{session_name}" 2>/dev/null)

if [ ${#SESSIONS[@]} -gt 0 ]; then
    default_new_name="$(get_next_session_name "$SESSION_NAME")"
    echo ""
    echo "  EllaMaka"
    echo "  ─────────────────────"
    for i in "${!SESSIONS[@]}"; do
        dir=$(tmux display-message -t "=${SESSIONS[$i]}" -p "#{pane_current_path}" 2>/dev/null || echo "?")
        # 用 ~ 缩写路径
        [[ "$dir" == "$HOME"* ]] && dir="~${dir#$HOME}"
        printf "  %d  %-28s %s\n" "$((i + 1))" "${SESSIONS[$i]}" "$dir"
    done
    echo ""
    printf "  %-2s %s\n" "↩" "新建 $default_new_name"
    printf "  %-2s %s\n" "q" "退出"
    echo ""
    read -p "  编号/名称 > " choice

    case "$choice" in
        "")  create_session "$default_new_name" ;;
        q|Q) exit 0 ;;
        *)
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#SESSIONS[@]} ]; then
                tmux attach-session -t "=${SESSIONS[$((choice - 1))]}"
            elif tmux has-session -t "=$choice" 2>/dev/null; then
                tmux attach-session -t "=$choice"
            else
                create_session "$choice"
            fi
            ;;
    esac
else
    create_session "$SESSION_NAME"
fi
